# ============================================================
# Tipsy — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ---------------------
# Required
# ---------------------

# Full domain where the app is deployed (no protocol, no trailing slash).
# Leave empty or set to "auto" for runtime detection (preview/local deployments).
# Example: tipsy.emsr.cc
VITE_APP_DOMAIN=auto

# ---------------------
# Optional — App
# ---------------------

# App name shown in header and PWA manifest
# Default: "Tipsy"
VITE_APP_NAME=Tipsy

# Initial theme: "tipsy" or "katzentempel"
# Default: "tipsy"
VITE_DEFAULT_THEME=tipsy

# Initial locale: "de" or "en"
# Default: "de"
VITE_DEFAULT_LANG=de

# ---------------------
# Optional — Auth (v1: not active)
# All four must be set for auth to activate.
# Partial configuration is ignored with a console warning.
# ---------------------

# OIDC provider URL (e.g. https://accounts.google.com)
# VITE_OIDC_AUTHORITY=

# OIDC client ID registered with your provider
# VITE_OIDC_CLIENT_ID=

# Redirect URI after successful login (must match provider config)
# VITE_OIDC_REDIRECT_URI=

# OIDC scopes (e.g. "openid profile email")
# VITE_OIDC_SCOPE=
